# ---- Docker dev ----
# Sladit UID/GID s hostem (spusť: id -u, id -g)
HOST_UID=1000
HOST_GID=1000

# ---- App ----
# Base path pro routing. V produkci na VPS: /padel, v dev obvykle prázdné.
NEXT_PUBLIC_BASE_PATH=

# ---- Database ----
DATABASE_URL=postgresql://padel:padel@postgres:5432/padel?schema=public

# ---- Auth.js ----
# Vygeneruj: openssl rand -base64 32
AUTH_SECRET=change-me
AUTH_TRUST_HOST=true
