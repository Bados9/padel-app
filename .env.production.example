# ============================================================
# Production env pro VPS deploy.
# Zkopíruj jako `.env` do adresáře s docker-compose.prod.yml.
# HESLA A SECRETY NIKDY NEUKLÁDÁME DO GITU.
# ============================================================

# ---- Routing ----
# Next.js basePath. Za reverse proxy pivnikonta běží na /padel.
# Dev obvykle prázdné (lokální `npm run dev` bez base path).
NEXT_PUBLIC_BASE_PATH=/padel

# ---- Database ----
# Heslo k postgres kontejneru. Používá se jen interně v padel_prod_network.
# Vygeneruj: openssl rand -base64 24
POSTGRES_PASSWORD=change-me-strong-password

# ---- Auth.js ----
# Vygeneruj: openssl rand -base64 32
AUTH_SECRET=change-me-long-random-secret

# AUTH_TRUST_HOST=true je už v compose; NextAuth dopočítá URL z Host hlavičky.

# ---- Optional: whitelist originů pro iframe embed (M6+) ----
# IFRAME_ALLOWED_ORIGINS=https://klub.example.com,https://dalsi.example.com
