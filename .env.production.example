# Produkční .env pro VPS (umísti jako `.env` do adresáře s docker-compose.prod.yml).
# HESLA A SECRETY NIKDY NEUKLÁDÁME DO GITU.

# ---- Routing ----
# Next.js basePath. V prod na VPS `/padel`, dev prázdné.
NEXT_PUBLIC_BASE_PATH=/padel

# ---- Database ----
# Silné heslo, vygeneruj: openssl rand -base64 24
POSTGRES_PASSWORD=change-me-strong-password

# ---- Auth.js ----
# Vygeneruj: openssl rand -base64 32
AUTH_SECRET=change-me-long-random-secret

# ---- Optional: whitelist originů pro iframe (M6+) ----
# IFRAME_ALLOWED_ORIGINS=https://klub.example.com,https://dalsi.example.com
